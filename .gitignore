.env
.env.*
!.env.example

# Frontend dependencies
node_modules/
.pnp/
.pnp.js

# Bun
.bun/
bun-debug.log*
*.bun-debug.log*

# Frontend build output
dist/
dist-ssr/
build/
.vite/

# TypeScript
*.tsbuildinfo

# Test and coverage output
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.tox/
.nox/
.cache/

# Python coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml

